# ─── Backend ────────────────────────────────────────────────────────────────
# Still named VITE_* during the transition period; Vite reads these via
# the define map in vite.config.ts. Rename to VITE_* when removing all
# VITE_* references from the codebase (Phase C / post-migration cleanup).
VITE_BACKEND_WS_URL=wss://dev-api.realityhack.world
VITE_BACKEND_URL=https://dev-api.realityhack.world

# ─── Keycloak (Browser PKCE public client) ───────────────────────────────────
# See docs/auth-environment.md for alignment with Django KEYCLOAK_* and EVENT_YEAR.
VITE_KEYCLOAK_ID=''
# Issuer must include /realms/<realm-name>
VITE_KEYCLOAK_ISSUER=''
# Client ID whose resource_access roles appear in the token (often same as VITE_KEYCLOAK_ID)
VITE_KEYCLOAK_ISSUER_CLIENT_ID=''
# Must match backend EVENT_YEAR (Keycloak roles use suffix :<year>)
VITE_EVENT_YEAR=''
# Optional: full URL allowlisted in Keycloak (defaults to <current-origin>/signin)
# VITE_KEYCLOAK_REDIRECT_URI=http://localhost:3000/signin

# ─── Feature flags ───────────────────────────────────────────────────────────
VITE_FEATURE_FLAGS='{"schedule":false,"team":true,"hardware":true,"showcase":true,"tracks":true,"workshops":true,"resources":true,"guide":true,"settings":true}'
VITE_IS_HOME_ENABLED=true
VITE_IS_ADMIN_ENABLED=true
VITE_IS_SCHEDULE_ENABLED=false
VITE_IS_TEAMS_ENABLED=true
VITE_IS_HARDWARE_CHECKOUT_ENABLED=true
VITE_IS_HACKER_HELP_ENABLED=true
VITE_IS_MENTOR_HELP_ENABLED=true
VITE_IS_WORKSHOPS_ENABLED=true
VITE_IS_HACKERS_MET_ENABLED=true
VITE_IS_EVENTS_ENABLED=true
VITE_IS_LIGHTHOUSES_ENABLED=false
VITE_IS_SPONSOR_DASHBOARD_ENABLED=false
VITE_IS_SHOWCASE_ENABLED=false
VITE_IS_TRACKS_ENABLED=false
VITE_IS_RESOURCES_TAB_ENABLED=false
VITE_IS_EVENT_GUIDE_ENABLED=false
VITE_IS_SETTINGS_TAB_ENABLED=true
VITE_TEAM_FORMATION_STAGE=1
