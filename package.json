    "vite": "^8.0.1",
    "@tailwindcss/typography": "^0.5.16",
    "@types/luxon": "^3.6.2",
    "@types/node": "20.4.2",
    "@types/react": "18.2.15",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.6",
    "openapi-typescript": "^6.7.6",
    "orval": "^7.9.0",
