    "@mui/icons-material": "7.0.1",
    "@mui/material": "7.0.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tanstack/react-table": "^8.21.2",
    "antd": "^5.24.6",
    "axios": "^1.8.4",
    "html5-qrcode": "^2.3.8",
    "jwt-decode": "^3.1.2",
    "jwt-encode": "^1.0.1",
    "keycloak-js": "^26.2.3",
    "react-router-dom": "^7.4.0",
    "konva": "^9.3.20",
    "luxon": "^3.6.1",
    "qr-scanner": "^1.4.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-dropzone": "^14.3.8",
    "react-icons": "^5.5.0",
    "react-konva": "^18.2.10",
    "react-markdown": "^9.1.0",
    "react-qr-code": "^2.0.15",
